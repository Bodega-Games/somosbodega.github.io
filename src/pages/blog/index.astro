---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Rodape from '../../components/Rodape.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.data.valueOf() - a.data.data.valueOf(),
);
const fmt = new Intl.DateTimeFormat('pt-BR', { dateStyle: 'long' });
---

<Base
  titulo="A Caderneta — Bodega Games"
  descricao="O caderno da Bodega: decisões de projeto, bastidores e aprendizados do estúdio, anotados em desenvolvimento aberto."
>
  <main class="caderneta">
    <div class="miolo">
      <a class="voltar" href={import.meta.env.BASE_URL}>← somos bodega</a>
      <p class="rotulo">O caderno da casa</p>
      <h1>A Caderneta</h1>
      <p class="sub">
        Onde a bodega anota tudo: decisões, bastidores e aprendizados — em
        desenvolvimento aberto.
      </p>
      {
        posts.map((post) => (
          <a class="entrada" href={`${import.meta.env.BASE_URL}blog/${post.id}/`}>
            <time datetime={post.data.data.toISOString()}>
              {fmt.format(post.data.data)}
            </time>
            <h3>{post.data.titulo}</h3>
            <p>{post.data.descricao}</p>
          </a>
        ))
      }
    </div>
  </main>
  <Rodape />
</Base>
